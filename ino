#include <Arduino.h>

// ---------------- ПІН ДЛЯ LDR ----------------

// GPIO 34 — це аналоговий вхід ESP32.
// До нього підключений фоторезистор.
// Через analogRead() будемо зчитувати рівень освітлення.
const int ldrPin = 34;


// ---------------- ПРАПОРЦІ ТАЙМЕРІВ ----------------

// volatile потрібне, бо ці змінні змінюються в перериваннях.
// Таймер спрацьовує не прямо в loop(), а окремо,
// тому компілятор має знати, що значення може змінитися в будь-який момент.

volatile bool timer0Flag = false;
// Прапорець для першого таймера.
// true означає: треба виконати дію для таймера 0.

volatile bool timer1Flag = false;
// Прапорець для другого таймера.
// true означає: треба виконати дію для таймера 1.


// ---------------- ОБ'ЄКТИ ТАЙМЕРІВ ----------------

// hw_timer_t — це тип апаратного таймера ESP32.
// Через ці змінні ми будемо керувати таймерами.

hw_timer_t *timer0 = NULL;
hw_timer_t *timer1 = NULL;


// ---------------- ОБРОБНИКИ ПЕРЕРИВАНЬ ----------------

// Ця функція викликається автоматично,
// коли спрацьовує перший таймер.
void IRAM_ATTR onTimer0() {
  timer0Flag = true;
  // Тут ми тільки ставимо прапорець.
  // Сам analogRead() і Serial.print() робимо в loop().
}

// Ця функція викликається автоматично,
// коли спрацьовує другий таймер.
void IRAM_ATTR onTimer1() {
  timer1Flag = true;
  // Те саме: тільки повідомляємо loop(),
  // що настав час виконати дію.
}


// ---------------- SETUP ----------------

void setup() {
  Serial.begin(115200);
  // Запускаємо Serial Monitor на швидкості 115200.

  delay(1000);
  // Невелика пауза, щоб монітор порту встиг підключитися.

  Serial.println("--- ДОСЛІДЖЕННЯ ТАЙМЕРІВ ESP32 ---");


  // ---------- НАЛАШТУВАННЯ ТАЙМЕРА 0 ----------

  // timerBegin(1000000) створює таймер з частотою 1 МГц.
  // 1 МГц = 1 000 000 тіків за секунду.
  // Тобто 1 тік = 1 мікросекунда.

  timer0 = timerBegin(1000000);

  // Прив'язуємо до таймера функцію onTimer0().
  // Коли таймер спрацює — викликається ця ISR-функція.
  timerAttachInterrupt(timer0, &onTimer0);

  // timerAlarm(timer0, 1000000, true, 0)
  // означає:
  // timer0 — який таймер використовуємо;
  // 1000000 — через скільки тіків він спрацює;
  // true — автоматично перезапускати таймер;
  // 0 — кількість повторів, 0 означає безкінечно.
  //
  // Оскільки частота таймера 1 000 000 тіків/сек,
  // то 1 000 000 тіків = 1 секунда.

  timerAlarm(timer0, 1000000, true, 0);


  // ---------- НАЛАШТУВАННЯ ТАЙМЕРА 1 ----------

  // Другий таймер теж працює на частоті 1 МГц.
  timer1 = timerBegin(1000000);

  // Прив'язуємо до другого таймера функцію onTimer1().
  timerAttachInterrupt(timer1, &onTimer1);

  // Тут таймер спрацьовує через 3 500 000 тіків.
  //
  // Якщо 1 000 000 тіків = 1 секунда,
  // то 3 500 000 тіків = 3.5 секунди.

  timerAlarm(timer1, 3500000, true, 0);


  Serial.println("Таймери запущені:");
  Serial.println("Таймер 0: кожну 1.0 сек");
  Serial.println("Таймер 1: кожні 3.5 сек");
}


// ---------------- LOOP ----------------

void loop() {

  // ---------- ОБРОБКА ТАЙМЕРА 0 ----------

  if (timer0Flag) {
    // Якщо timer0Flag == true,
    // значить пройшла 1 секунда і таймер 0 спрацював.

    int val = analogRead(ldrPin);
    // Зчитуємо значення з фоторезистора.
    // На ESP32 analogRead зазвичай повертає число приблизно від 0 до 4095.

    Serial.print("[Таймер 0 (1с)]: Зчитування LDR = ");
    Serial.println(val);
    // Виводимо значення в Serial Monitor.

    timer0Flag = false;
    // Скидаємо прапорець, щоб ця дія не повторювалася постійно.
    // Наступного разу він знову стане true через 1 секунду.
  }


  // ---------- ОБРОБКА ТАЙМЕРА 1 ----------

  if (timer1Flag) {
    // Якщо timer1Flag == true,
    // значить пройшло 3.5 секунди і таймер 1 спрацював.

    int val = analogRead(ldrPin);
    // Знову зчитуємо значення з того самого LDR.

    Serial.print(">>> [Таймер 1 (3.5с)]: Важливе зчитування LDR = ");
    Serial.println(val);
    // Виводимо окреме повідомлення для другого таймера.

    timer1Flag = false;
    // Скидаємо прапорець.
    // Наступне спрацювання буде знову через 3.5 секунди.
  }
}
